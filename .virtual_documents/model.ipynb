def preprocess_text(text):
    # 1. Unicode Normalization
    text = unicodedata.normalize("NFKC", text)
    # print(text, "\n\n")
    # 2. Remove Tabs
    text = text.replace("\t", " ")

    # 3. Remove Multiple Spaces
    text = re.sub(r"[ ]+", " ", text)

    # 4. Remove Multiple Blank Lines
    text = re.sub(r"\n+", "\n", text)

    # 5. Remove Leading and Trailing Spaces
    text = text.strip()

    return text


