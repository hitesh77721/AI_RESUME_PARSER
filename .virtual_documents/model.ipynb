def load_degrees(file_path):
    with open(file_path, "r", encoding="utf-8") as file:
        degrees = [line.strip() for line in file if line.strip()]

    return degrees


from spacy.matcher import PhraseMatcher

degree_matcher = PhraseMatcher(nlp.vocab, attr="LOWER")
degrees = load_degrees("degrees.txt")
patterns = [nlp(degree) for degree in degrees]
degree_matcher.add("DEGREES", patterns)


import re

def extract_education(text):

    doc = nlp(text)

    education = {

        "degrees": [],
        "institutions": [],
        "years": []

    }

    # -------- Degree Extraction --------

    matches = degree_matcher(doc)

    for match_id, start, end in matches:

        degree = doc[start:end].text

        education["degrees"].append(degree)

    # -------- Institution Extraction --------

    for entity in doc.ents:

        if entity.label_ == "ORG":

            if any(keyword in entity.text.lower() for keyword in
                   ["college", "university", "institute", "school"]):

                education["institutions"].append(entity.text)

    # -------- Graduation Year --------

    pattern = r"\b(?:19|20)\d{2}\b"

    years = re.findall(pattern, text)

    education["years"] = years

    # Remove duplicates

    education["degrees"] = list(set(education["degrees"]))
    education["institutions"] = list(set(education["institutions"]))
    education["years"] = list(set(education["years"]))

    return education


education = extract_education(clean_text)
print(education)


import re

def extract_experience(text):
    pattern = r"EXPERIENCE(.*?)(PROJECTS|CERTIFICATIONS|EDUCATION|LANGUAGES|$)"

    match = re.search(
        pattern,
        text,
        flags=re.IGNORECASE | re.DOTALL
    )

    if not match:

        return None

    experience_text = match.group(1).strip()

    return experience_text


experience = extract_experience(clean_text)
print(experience)


import re

def extract_projects(text):
    pattern = r"PROJECTS?(.*?)(CERTIFICATIONS|ACHIEVEMENTS|LANGUAGES|INTERESTS|EXPERIENCE|$)"

    match = re.search(
        pattern,
        text,
        flags=re.IGNORECASE | re.DOTALL
    )

    if match:

        projects = match.group(1).strip()

        return projects

    return None


projects = extract_projects(clean_text)
print(projects)


def load_certifications(file_path):
    with open(file_path, "r", encoding="utf-8") as file:

        certifications = [
            line.strip()
            for line in file
            if line.strip()
        ]

    return certifications


from spacy.matcher import PhraseMatcher

certification_matcher = PhraseMatcher(nlp.vocab, attr="LOWER")
certifications = load_certifications("certifications.txt")
patterns = [nlp(certification) for certification in certifications]
certification_matcher.add("CERTIFICATIONS", patterns)


def extract_certifications(text):
    doc = nlp(text)

    matches = certification_matcher(doc)

    extracted = []

    for match_id, start, end in matches:

        certification = doc[start:end].text

        extracted.append(certification)

    return sorted(list(set(extracted)))


certifications = extract_certifications(clean_text)
print(certifications)


